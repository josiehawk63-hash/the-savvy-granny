---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with The Savvy Granny — questions, recipe requests, and partnership inquiries welcome."
>
  <article class="container page">
    <span class="eyebrow">Say hello</span>
    <h1>Contact</h1>
    <p>
      Got a question, a recipe request, or just want to say hi? I'd love to hear from you.
    </p>

    <!-- Submissions are emailed via Web3Forms to josiehawk63@gmail.com. -->
    <form class="contact-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="7350cc9a-1d25-44aa-b6ac-2c8612fd9084" />
      <input type="hidden" name="subject" value="New contact message — The Savvy Granny" />
      <input type="hidden" name="from_name" value="The Savvy Granny website" />
      <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
      <label>
        Your name
        <input type="text" name="name" required />
      </label>
      <label>
        Your email
        <input type="email" name="email" required />
      </label>
      <label>
        Message
        <textarea name="message" rows="5" required></textarea>
      </label>
      <button type="submit" class="btn">Send message</button>
    </form>
  </article>
</BaseLayout>

<style>
  .page { max-width: 640px; padding: 2.5rem 1.25rem 2rem; }
  .page h1 { font-size: 2.3rem; margin: 0.3rem 0 0.8rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.2rem; }
  label { font-weight: 700; display: flex; flex-direction: column; gap: 0.35rem; }
  input, textarea {
    font: inherit; padding: 0.6rem 0.7rem; border: 1px solid var(--line);
    border-radius: 10px; background: var(--surface); font-weight: 400;
  }
  input:focus, textarea:focus { outline: 2px solid var(--brand); border-color: var(--brand); }
  button { align-self: flex-start; border: none; cursor: pointer; }
  .note { font-size: 0.85rem; margin-top: 0.8rem; }
</style>
