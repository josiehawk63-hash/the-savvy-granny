---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page slipped out of the recipe box." noindex={true}>
  <section class="container nf">
    <div class="big">🍳</div>
    <h1>Hmm, that page isn't on the menu.</h1>
    <p class="muted">The page you're looking for moved or never existed.</p>
    <p><a class="btn" href="/">Back to home</a> &nbsp; <a href="/recipes">Browse recipes</a></p>
  </section>
</BaseLayout>

<style>
  .nf { text-align: center; padding: 4rem 1.25rem; }
  .big { font-size: 3.5rem; }
  .nf h1 { font-size: 2rem; margin: 0.5rem 0; }
</style>
